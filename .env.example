# X/Twitter API Credentials
# Get your credentials from https://developer.x.com/en/portal/dashboard

# OAuth 1.0a — Full read + write access (post, reply, like, retweet, follow)
X_APP_KEY=your-consumer-key
X_APP_SECRET=your-consumer-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_SECRET=your-access-token-secret

# Bearer Token — App-only read access (search, timelines, profiles)
# Use this alone for read-only setups; OAuth 1.0a takes priority when both are set
# X_BEARER_TOKEN=your-bearer-token

# Optional Hermes Tweet/Xquik backend for x_search_tweets only
# HERMES_TWEET_API_KEY=xq_your-key
# X_SEARCH_BACKEND=hermes-tweet
# XQUIK_BASE_URL=https://xquik.com
